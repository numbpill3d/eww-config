      (label :class "kb-desc" :text "wardrive map"))))

;; Sway nav quick-ref — compact sidebar panel
(defwidget w-navkeys []
  (box :class "panel" :orientation "v" :spacing 1
    (label :class "section-label" :text "[ NAV ]" :halign "start")
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "hjkl" :width 46)
      (label :class "stat-val"  :text "focus"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "sft+hjk;" :width 46)
      (label :class "stat-val"  :text "move"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "1..0" :width 46)
      (label :class "stat-val"  :text "ws"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "sft+1..0" :width 46)
      (label :class "stat-val"  :text "send ws"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "q/f/r" :width 46)
      (label :class "stat-val"  :text "kill/fs/resize"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "d/ret" :width 46)
      (label :class "stat-val"  :text "launch/term"))
    (box :class "kb-row" :orientation "h" :spacing 3
      (label :class "label-dim" :text "/" :width 46)
      (label :class "stat-val"  :text "keys ref"))))

;; ---- WINDOWS ----

;; LEFT SIDEBAR — clock, vitals, rf scan, nav keys
(defwindow sidebar-left
  :monitor 0
  :geometry (geometry :x "0px" :y "0px" :width "180px" :height "100%"
                      :anchor "top left")
  :stacking "bottom"
  :exclusive true
  :namespace "eww-sidebar"
  (box :class "root" :orientation "v" :spacing 4 :valign "start" :halign "fill"
    (w-clock)
    (w-vitals)
    (w-rf-radar)
    (w-navkeys)))

;; RIGHT SIDEBAR — github, youtube, claude code
(defwindow sidebar-right
  :monitor 0
  :geometry (geometry :x "0px" :y "0px" :width "180px" :height "100%"
                      :anchor "top right")
  :stacking "bottom"
  :exclusive true
  :namespace "eww-sidebar-r"
  (box :class "root" :orientation "v" :spacing 6 :valign "start" :halign "fill"
    (w-github)
    (w-youtube)
    (w-claudecode)))

;; KEYBINDINGS REFERENCE — centered overlay, toggled with mod+/
(defwindow keybindings-ref
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "380px" :height "560px"
                      :anchor "center")
  :stacking "overlay"
  :focusable false
  (w-keybindings))

;; ---- AGENT WINDOWS (three separate windows, buttons swap between them) ----

;; HOME — matrix animation + nav buttons
(defwindow agent-chat
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "260px" :height "260px"
                      :anchor "center")
  :stacking "overlay"
  :focusable true
  :namespace "eww-agent"
  (box :class "agent-root" :orientation "v" :spacing 0
    ;; header strip — title, status dot, model
    (box :class "agent-topbar" :orientation "h" :spacing 0 :valign "center"
      (label :class "agent-title" :hexpand true :text "[ XENOTREK ]" :halign "start")
      (label :class {"agent-status-dot " + agent_status}
             :text {agent_status == "running" ? "●" : "·"})
      (label :class "agent-sep" :text "  ")
      (label :class "agent-model-sm" :text agent_model))
    ;; matrix — fill remaining space, no centering
    (box :class "agent-matrix-wrap" :vexpand true :hexpand true
      (label :class "agent-matrix-txt" :text agent_matrix
             :vexpand true :hexpand true :halign "start" :valign "start"
             :wrap false))
    ;; nav / quick-input bar
    (box :class "agent-homebar" :orientation "h" :spacing 0 :valign "center"
      (button :class "agent-navbtn"
              :onclick "eww close agent-chat; eww open agent-agents"
        (label :text "[agents]"))
      (label :class "agent-sep" :text " ")
      (button :class "agent-navbtn"
              :onclick "eww close agent-chat; eww open agent-chat-view"
        (label :text "[chat]"))
      (label :class "agent-prompt" :text " ›")
      (input :class "agent-input" :value agent_input :hexpand true
             :onaccept "eww update 'agent_input={}' && bash ~/.config/eww/scripts/agent_run.sh &"))))

;; CHAT — conversation display + input
;;
;; HEIGHT BUDGET (keep these two numbers in sync):
;;   window :height  360px  ← geometry below
;;   scroll :height  200px  ← inside the widget tree
;;   GTK measures bars differently from CSS padding math.
;;   topbar+inputbar+border measured at ~140px (original working baseline),
;;   modelbar adds ~20px → fixed total ~160px.
;;   formula: scroll = window(360) - fixed(160) = 200
;;   to resize: change window height N, change scroll height by same N.
;;
(defwindow agent-chat-view
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "460px" :height "360px"
                      :anchor "center")
  :stacking "overlay"
  :focusable true
  :namespace "eww-agent"
  (box :class "agent-root" :orientation "v" :spacing 0
    ;; top bar — back, title, status dot, clear
    (box :class "agent-topbar" :orientation "h" :spacing 0 :valign "center"
      (button :class "agent-back"
              :onclick "eww close agent-chat-view; eww open agent-chat"
        (label :text "←"))
      (label :class "agent-title" :hexpand true :text "[ CHAT ]" :halign "start")
      (label :class {"agent-status-dot " + agent_status}
             :text {agent_status == "running" ? "●" : "·"})
      (label :class "agent-sep" :text "  ")
      (button :class "agent-clr" :onclick "printf '' > /tmp/eww_agent_conv"
        (label :text "clr")))
    ;; model selector strip — click cycles installed ollama models
    (box :class "agent-modelbar" :orientation "h" :spacing 0 :valign "center"
      (label :class "agent-set-label" :text "mod ")
      (button :class "agent-modcycle"
              :onclick "bash ~/.config/eww/scripts/agent_model_cycle.sh"
        (label :text agent_model))
      (label :class {"agent-runlabel " + agent_status} :hexpand true :halign "end"
             :text {agent_status == "running" ? "[ running ]" : "[ idle ]"}))
    ;; scrollable conversation — height = window(360) - fixed-bars(160)
    (scroll :vscroll true :height 200 :class "agent-scroll"
      (box :class "agent-screen"
        (label :class "agent-display" :text agent_display
               :wrap false :halign "start" :valign "start")))
    ;; input bar — prompt glyph changes to » when running
    (box :class "agent-inputbar" :orientation "h" :spacing 0
      (label :class {"agent-prompt " + agent_status}
             :text {agent_status == "running" ? "»" : "›"})
      (input :class "agent-input" :value agent_input :hexpand true
             :onaccept "eww update 'agent_input={}' && bash ~/.config/eww/scripts/agent_run.sh &"))))

;; AGENTS — launcher cards
(defwindow agent-agents
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "340px" :height "230px"
                      :anchor "center")
  :stacking "overlay"
  :focusable true
  :namespace "eww-agent"
  (box :class "agent-root" :orientation "v" :spacing 0
    (box :class "agent-topbar" :orientation "h" :spacing 0 :valign "center"
      (button :class "agent-back"
              :onclick "eww close agent-agents; eww open agent-chat"
        (label :text "←"))
      (label :class "agent-title" :hexpand true :text "[ AGENTS ]" :halign "start"))
    (box :class "agent-agentsview" :orientation "v" :spacing 5
      (box :class "agent-card" :orientation "h" :spacing 0 :valign "center"
        (box :orientation "v" :spacing 0 :hexpand true
          (label :class "agent-card-name" :text "zeroclaw" :halign "start")
          (label :class "agent-card-desc" :text "openrouter free  //  llama-3.3-70b" :halign "start"))
        (button :class "agent-launch"
                :onclick "bash ~/.config/eww/scripts/launch_agent.sh zeroclaw"
          (label :text "[open]")))
      (box :class "agent-card" :orientation "h" :spacing 0 :valign "center"
        (box :orientation "v" :spacing 0 :hexpand true
          (label :class "agent-card-name" :text "goose" :halign "start")
          (label :class "agent-card-desc" :text "block agent  //  gemini 2.5 pro" :halign "start"))
        (button :class "agent-launch"
                :onclick "bash ~/.config/eww/scripts/launch_agent.sh goose"
          (label :text "[open]")))
      (box :class "agent-card" :orientation "h" :spacing 0 :valign "center"
        (box :orientation "v" :spacing 0 :hexpand true
          (label :class "agent-card-name" :text "claude" :halign "start")
          (label :class "agent-card-desc" :text "claude code  //  sonnet 4.6" :halign "start"))
        (button :class "agent-launch"
                :onclick "bash ~/.config/eww/scripts/launch_agent.sh claude"
          (label :text "[open]"))))))

;; ---- SCAN PANEL (workspace 2) ----
;;
;; HEIGHT BUDGET: window=320  topbar=30  col-header=26  col-scroll=120  focus=24+60+24  pad=~24
;;   30+26+120+108+24 = 308 → 320 gives 12px breathing room
;;   to resize: change :height here AND both scroll heights below in lockstep

(defwidget w-scan-panel []
  (box :class "scan-root" :orientation "v" :spacing 0 :valign "start" :vexpand false

    ;; ── TOP BAR ──────────────────────────────────────────────────────────────
    (box :class "scan-topbar" :orientation "h" :spacing 0 :valign "center"
      (label :class "scan-title" :hexpand true :text "[ SCAN ]" :halign "start")
      (label :class "rf-spinner" :text rf_pulse)
      (label :class "agent-sep"  :text "  ")
      (label :class "rf-summary" :text {"w:" + wifi_count + "  " + rf_summary})
      (label :class "agent-sep"  :text "  ")
      (label :class "wardrive-stat-sm" :text wardrive_stats)
      (label :class "agent-sep"  :text "  ")
      (button :class "scan-rbtn"
              :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json & ~/.config/eww/scripts/rf_live.sh &"
        (label :text "[r all]")))

    ;; ── TABS ─────────────────────────────────────────────────────────────────
    (box :class "scan-tabs" :orientation "h" :spacing 0
      (button :class {scan_tab == "wifi" ? "scan-tab scan-tab-active" : "scan-tab"}
              :onclick "eww update scan_tab=wifi"
        (label :text "[ wifi ]"))
      (button :class {scan_tab == "arp" ? "scan-tab scan-tab-active" : "scan-tab"}
              :onclick "eww update scan_tab=arp"
        (label :text "[ arp ]"))
      (button :class {scan_tab == "bt" ? "scan-tab scan-tab-active" : "scan-tab"}
              :onclick "eww update scan_tab=bt"
        (label :text "[ bt ]")))

    ;; ── WIFI TAB ─────────────────────────────────────────────────────────────
    (revealer :reveal {scan_tab == "wifi"} :transition "none"
      (box :orientation "v" :spacing 0
        (box :class "scan-section-hdr" :orientation "h" :spacing 3 :valign "center"
          (label :class "scan-col-title" :hexpand true :text "[ WIFI NETWORKS ]" :halign "start")
          (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse)
          (label :class "agent-sep" :text " ")
          (button :class "scan-rbtn"
                  :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json &"
            (label :text "[r]")))
        (scroll :class "scan-scroll" :vscroll true :height 150
          (box :orientation "v" :spacing 0
            (for ap in wifi_devices
              (box :class "scan-ap-row" :orientation "v" :spacing 0
                (button :class "scan-row-btn"
                        :tooltip {ap.ssid + "  [" + ap.security + "]\n"
                                  + ap.bssid + "  " + ap.dbm + "dBm\n"
                                  + "ch" + ap.chan + "  " + ap.band + "  " + ap.signal + "%"}
                        :onclick {"~/.config/eww/scripts/scan_select.sh wifi '"
                                  + ap.bssid + "'"}
                  (box :orientation "h" :spacing 2
                    (label :class {"scan-wsig scan-wsig-" + ap.level}
                           :text {ap.bars} :width 26)
                    (label :class {"scan-sec scan-sec-" + ap.security}
                           :text {ap.security} :width 40)
                    (label :class "scan-ssid" :hexpand true
                           :text {ap.ssid == wifi_ssid ? "* " + ap.ssid : ap.ssid}
                           :truncate true :limit-width 22)
                    (label :class "scan-chan"
                           :text {"ch" + ap.chan} :width 30)
                    (label :class "scan-band" :text {ap.band} :width 28)
                    (label :class "scan-sigpct"
                           :text {ap.signal + "%"} :width 30)
                    (label :class "scan-dist"
                           :text {ap.dist_s} :width 38)))
                (box :orientation "h" :spacing 2
                  (label :class "scan-indent" :width 26 :text "")
                  (label :class "scan-bssid"
                         :text {ap.bssid} :limit-width 18 :width 110)
                  (label :class "scan-dbm" :hexpand true
                         :text {ap.dbm + "dBm"})
                  (button :class "scan-cpbtn"
                          :onclick {"wl-copy '" + ap.bssid + "'"}
                    (label :text "[cp]")))))))))

    ;; ── ARP TAB ──────────────────────────────────────────────────────────────
    (revealer :reveal {scan_tab == "arp"} :transition "none"
      (box :orientation "v" :spacing 0
        (box :class "scan-section-hdr" :orientation "h" :spacing 3 :valign "center"
          (label :class "scan-col-title" :hexpand true :text "[ ARP DEVICES ]" :halign "start")
          (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse)
          (label :class "agent-sep" :text " ")
          (button :class "scan-rbtn"
                  :onclick "~/.config/eww/scripts/rf_live.sh &"
            (label :text "[r]")))
        (scroll :class "scan-scroll" :vscroll true :height 150
          (box :orientation "v" :spacing 0
            (for device in arp_devices
              (box :class {"scan-rf-row rf-" + device.new} :orientation "v" :spacing 0
                (button :class {"scan-row-btn rf-known-" + device.new}
                        :tooltip {device.display + "  [" + device.dtype + "]\n"
                                  + device.addr + "  " + device.mac + "\n"
                                  + device.vendor + "  state: " + device.state}
                        :onclick {"~/.config/eww/scripts/scan_select.sh arp '"
                                  + device.key + "'"}
                  (box :orientation "h" :spacing 2
                    (label :class {"rf-cdot " + device.colorclass} :text "■" :width 12)
                    (label :class {"rf-sig " + device.state}
                           :text {device.sig} :width 26)
                    (label :class {"rf-dtype rf-dtype-" + device.dtype}
                           :text {device.dtype} :width 28)
                    (label :class {"scan-devname rf-new-" + device.new}
                           :hexpand true :text {device.display}
                           :truncate true :limit-width 20)
                    (label :class {"rf-state " + device.state}
                           :text {device.state_s} :limit-width 7 :width 40)
                    (label :class {"scan-dist scan-dist-" + device.dist_s}
                           :text {device.dist_s} :width 36)))
                (box :orientation "h" :spacing 2
                  (label :class "scan-indent" :width 26 :text "")
                  (label :class "rf-addr-sm"
                         :text {device.addr} :limit-width 15 :width 95)
                  (label :class {"rf-vendor rf-dtype-" + device.dtype}
                         :hexpand true :text {device.vendor}
                         :limit-width 12 :truncate true)
                  (button :class "scan-cpbtn"
                          :onclick {"wl-copy '" + device.key + "'"}
                    (label :text "[cp]"))
                  (button :class {"rf-mark-btn rf-mark-" + device.new}
                          :onclick {"~/.config/eww/scripts/rf_mark.sh '"
                                    + device.key + "'"}
                    (label :text "+kn")))))))))

    ;; ── BT TAB ───────────────────────────────────────────────────────────────
    (revealer :reveal {scan_tab == "bt"} :transition "none"
      (box :orientation "v" :spacing 0
        (box :class "scan-section-hdr" :orientation "h" :spacing 3 :valign "center"
          (label :class "scan-col-title" :hexpand true :text "[ BLUETOOTH ]" :halign "start")
          (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))
        (scroll :class "scan-scroll" :vscroll true :height 150
          (box :orientation "v" :spacing 0
            (for device in bt_devices
              (box :class {"scan-rf-row rf-" + device.new} :orientation "v" :spacing 0
                (button :class {"scan-row-btn rf-known-" + device.new}
                        :tooltip {device.display + "  [bt/" + device.dtype + "]\n"
                                  + device.mac + "\n"
                                  + device.vendor + "  state: " + device.state}
                        :onclick {"~/.config/eww/scripts/scan_select.sh bt '"
                                  + device.key + "'"}
                  (box :orientation "h" :spacing 2
                    (label :class {"rf-cdot " + device.colorclass} :text "■" :width 12)
                    (label :class {"rf-sig " + device.state}
                           :text {device.sig} :width 26)
                    (label :class {"rf-badge rf-badge-bt"} :text "bt" :width 24)
                    (label :class {"rf-dtype rf-dtype-" + device.dtype}
                           :text {device.dtype} :width 28)
                    (label :class {"scan-devname rf-new-" + device.new}
                           :hexpand true :text {device.display}
                           :truncate true :limit-width 22)
                    (label :class {"rf-state " + device.state}
                           :text {device.state_s} :limit-width 6 :width 36)
                    (label :class {"scan-dist scan-dist-" + device.dist_s}
                           :text {device.dist_s} :width 36)))
                (box :orientation "h" :spacing 2
                  (label :class "scan-indent" :width 26 :text "")
                  (label :class "rf-addr-sm"
                         :text {device.addr} :limit-width 15 :width 95)
                  (label :class {"rf-vendor rf-dtype-" + device.dtype}
                         :hexpand true :text {device.vendor}
                           :limit-width 14 :truncate true)
                  (button :class "scan-cpbtn"
                          :onclick {"wl-copy '" + device.key + "'"}
                    (label :text "[cp]"))
                  (button :class {"rf-mark-btn rf-mark-" + device.new}
                          :onclick {"~/.config/eww/scripts/rf_mark.sh '"
                                    + device.key + "'"}
                    (label :text "+kn")))))))))



    ;; ── FOCUS PANEL ──────────────────────────────────────────────────────────
    (box :class "scan-focus-wrap" :orientation "v" :spacing 0
      (box :class "scan-focus-header" :orientation "h" :spacing 3 :valign "center"
        (label :class "scan-col-title" :hexpand true
               :text "[ FOCUS ]" :halign "start")
        (label :class "scan-focused-key" :text {scan_focused_key} :limit-width 20)
        (button :class "scan-unk-btn"
                :onclick {"~/.config/eww/scripts/rf_unmark.sh '" + scan_focused_key + "'"}
          (label :text "[unmark]"))
        (label :class "agent-sep" :text "  ")
        (button :class "scan-rbtn"
                :onclick "truncate -s 0 /tmp/eww_scan_focus"
          (label :text "[clr]")))
      (scroll :class "scan-scroll" :vscroll true :height 55
        (label :class "scan-focus-text" :halign "start" :valign "start"
               :wrap false :text scan_focus_data))
      (box :class "scan-focus-actions" :orientation "h" :spacing 4 :valign "center"
        (label :class "scan-nick-label" :text "nick:")
        (input :class "scan-nick-input" :hexpand true
               :onaccept "~/.config/eww/scripts/rf_nick_focused.sh '{}'")
        (button :class "scan-cpbtn"
                :onclick "~/.config/eww/scripts/rf_nick_focused.sh '-'"
          (label :text "[clr]")))
      ;; color assignment row — sets radar blip color for focused device
      (box :class "scan-color-row" :orientation "h" :spacing 3 :valign "center"
        (label :class "scan-nick-label" :text "col:")
        (button :class "rf-cbtn c-red"    :tooltip "red"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-red"
          (label :text "■"))
        (button :class "rf-cbtn c-orange" :tooltip "orange"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-orange"
          (label :text "■"))
        (button :class "rf-cbtn c-yellow" :tooltip "yellow"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-yellow"
          (label :text "■"))
        (button :class "rf-cbtn c-green"  :tooltip "green"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-green"
          (label :text "■"))
        (button :class "rf-cbtn c-cyan"   :tooltip "cyan"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-cyan"
          (label :text "■"))
        (button :class "rf-cbtn c-white"  :tooltip "white"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-white"
          (label :text "■"))
        (button :class "rf-cbtn c-pink"   :tooltip "pink"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh c-pink"
          (label :text "■"))
        (button :class "scan-cpbtn"
                :onclick "~/.config/eww/scripts/rf_color_focused.sh ''"
          (label :text "[def]"))))))

(defwindow scan-panel
  :monitor 0
  :geometry (geometry :x "560px" :y "30px" :width "700px" :height "390px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable true
  (w-scan-panel))

;; ---- RADAR PANEL (workspace 2, right column lower) ----

(defwidget w-radar []
  (box :class "root" :orientation "v" :spacing 0
    (box :class "panel ws2-radar-panel" :orientation "v" :spacing 2

      ;; header: title + spinning indicator + contact count
      (box :orientation "h" :spacing 3 :valign "center"
        (label :class "section-label" :hexpand true
               :text "[ RADAR ]" :halign "start")
        (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse)
        (label :class "agent-sep" :text " ")
        (button :class "rf-scan-micro"
                :onclick "~/.config/eww/scripts/rf_live.sh & ~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json &"
          (label :text "[r]")))

      ;; radar frame — updates every 500ms, plain text X blips
      (label :class "ws2-radar-txt" :halign "start" :valign "start"
             :wrap false :text radar_frame))))

(defwindow radar-panel
  :monitor 0
  :geometry (geometry :x "1270px" :y "248px" :width "380px" :height "430px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable false
  (w-radar))

;; ---- PULSE STRIP (workspace 2, below scan-panel) ----
;; shows: ping latency sparkline / live net flow / dns resolver / public ip / channel congestion

(defwidget w-scan-pulse []
  (box :class "pulse-root" :orientation "v" :spacing 0 :vexpand false

    ;; ── ROW 1: network pulse ────────────────────────────────────────────────
    (box :class "pulse-row" :orientation "h" :spacing 0 :valign "center"
      (label :class "pulse-title" :text "[ PULSE ]")
      (label :class "pulse-sep"   :text "  ")
      (label :class "pulse-lbl"   :text "gw:")
      (label :class "pulse-val"   :text ping_ms :width 36)
      (label :class "pulse-spark" :text ping_spark)
      (label :class "pulse-sep"   :text "   ")
      (label :class "pulse-arrow" :text "↑")
      (label :class "pulse-val"   :text net_up  :width 52 :halign "start")
      (label :class "pulse-arrow" :text "↓")
      (label :class "pulse-val"   :text net_down :hexpand true :halign "start")
      (label :class "pulse-lbl"   :text "dns:")
      (label :class "pulse-val"   :text dns_server :width 76)
      (label :class "pulse-lbl"   :text "ext:")
      (label :class "pulse-val"   :text pub_ip :width 84)
      (button :class "scan-rbtn"
              :onclick "~/.config/eww/scripts/dns_probe.sh &"
        (label :text "[r]")))

    ;; ── ROW 2: wifi channel congestion ──────────────────────────────────────
    (box :class "pulse-chan-wrap" :orientation "h" :spacing 0 :valign "start"
      (label :class "pulse-title" :text "[ CHAN ]" :valign "start")
      (label :class "pulse-sep"   :text "  " :valign "start")
      (scroll :class "pulse-chan-scroll" :vscroll true :hscroll false :height 78
        (label :class "pulse-chan-text" :halign "start" :valign "start"
               :wrap false :text chan_bars)))))

(defwindow scan-pulse
  :monitor 0
  :geometry (geometry :x "610px" :y "568px" :width "720px" :height "80px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable false
  (w-scan-pulse))

