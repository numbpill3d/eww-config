      (label :class "stat-val accent" :text yt_subs))
    (box :class "stat-row" :orientation "h" :spacing 8
      (label :class "label-dim" :text "views")
      (label :class "stat-val" :text yt_views))
    (box :class "stat-row" :orientation "h" :spacing 8
      (label :class "label-dim" :text "vids")
      (label :class "stat-val" :text yt_videos))
    (label :class "section-label" :text "---" :halign "start")
    (label :class "label-dim" :text yt_title2)
    (box :class "stat-row" :orientation "h" :spacing 8
      (label :class "label-dim" :text "subs")
      (label :class "stat-val accent" :text yt2_subs))
    (box :class "stat-row" :orientation "h" :spacing 8
      (label :class "label-dim" :text "views")
      (label :class "stat-val" :text yt2_views))
    (box :class "stat-row" :orientation "h" :spacing 8
