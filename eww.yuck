      (label :class "stat-val" :text yt2_videos))))

;; ---- WORKSPACE 2 PANELS ----

;; Channel congestion — groups wifi scan by channel, shows fill bars + bandwidth
(defwidget w-chan-bars []
  (box :class "root" :orientation "v" :spacing 0
    (box :class "panel ws2-chan" :orientation "v" :spacing 2

      ;; header: title + live spinner + reload
      (box :orientation "h" :spacing 3 :valign "center"
        (label :class "section-label" :text "[ CHAN ]" :hexpand true :halign "start")
        (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse)
        (label :class "agent-sep" :text " ")
        (button :class "rf-scan-micro"
                :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json &"
          (label :text "[r]")))

      ;; channel congestion bars — scrollable so long lists don't overflow
      (scroll :class "scan-scroll ws2-chan-scroll" :vscroll true :height 170
        (label :class "ws2-bars-txt ws2-bars-anim" :halign "start" :valign "start"
               :wrap false :text chan_bars))

      ;; bandwidth section
      (box :orientation "h" :spacing 3 :valign "center"
        (label :class "section-label" :text "[ BWIDTH ]" :hexpand true :halign "start")
        (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))

      ;; real iface counters — DN/UP bar visualization
      (label :class "ws2-bw-txt" :halign "start" :valign "start"
             :wrap true :text net_bw))))

;; Network panel — latency sparkline, throughput, DNS, public IP, RF summary
(defwidget w-ping []
  (box :class "root" :orientation "v" :spacing 0
    (box :class "panel ws2-net" :orientation "v" :spacing 2

      ;; latency
      (box :orientation "h" :spacing 3 :valign "center"
        (label :class "section-label" :text "[ LATENCY ]" :hexpand true :halign "start")
        (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))
      (box :class "stat-row" :orientation "h" :spacing 6
        (label :class "label-dim" :text "gw")
        (label :class "stat-val ws2-ping-val" :text ping_ms))
      (label :class "ws2-spark" :halign "start" :text ping_spark)

      ;; net throughput
      (label :class "section-label" :text "[ NET ]" :halign "start")
      (box :class "stat-row" :orientation "h" :spacing 6
        (label :class "label-dim" :text "up")
        (label :class "stat-val" :text net_up))
      (box :class "stat-row" :orientation "h" :spacing 6
        (label :class "label-dim" :text "dn")
        (label :class "stat-val" :text net_down))

      ;; dns + external ip
      (label :class "section-label" :text "[ DNS / EXT ]" :halign "start")
      (box :class "stat-row" :orientation "h" :spacing 6
        (label :class "label-dim" :text "dns")
        (label :class "stat-val ws2-net-ip" :text dns_server))
      (box :class "stat-row" :orientation "h" :spacing 6
        (label :class "label-dim" :text "ext")
        (label :class "stat-val ws2-net-ip" :text pub_ip))

      ;; RF device summary
      (box :orientation "h" :spacing 3 :valign "center"
        (label :class "section-label" :text "[ RF ]" :hexpand true :halign "start")
        (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))
      (label :class "rf-summary ws2-rf-sum ws2-rf-live" :halign "start"
             :text rf_summary))))

;; channel congestion + bandwidth — workspace 2, left column
(defwindow chan-panel
  :monitor 0
  :geometry (geometry :x "190px" :y "30px" :width "360px" :height "530px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable false
  (w-chan-bars))

;; latency / net / dns / rf — workspace 2, right column upper
(defwindow net-panel
  :monitor 0
  :geometry (geometry :x "1270px" :y "30px" :width "380px" :height "210px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable false
  (w-ping))
(defwindow ws2-sidebar-right
  :monitor 0
  :geometry (geometry :x "0px" :y "0px" :width "390px" :height "100%"
                      :anchor "top right")
  :stacking "bottom"
  :exclusive false
  :namespace "eww-sidebar-r"
  (box :class "root" :orientation "v" :spacing 10 :valign "start" :halign "fill"
    (w-ping)
    (w-radar)))

;; ---- WORKSPACE 2: ACTION BAR (lower-left, below chan-panel) ----
;; positioned at x=190 y=568 — fills the empty zone beneath the chan-panel
;; buttons trigger real scans, open labeler, export, clear-new

(defwidget w-ws2-actions []
  (box :class "ws2-actions-root" :orientation "v" :spacing 4

    ;; header
    (box :class "scan-section-hdr" :orientation "h" :spacing 3 :valign "center"
      (label :class "scan-col-title" :hexpand true :text "[ ACTIONS ]" :halign "start")
      (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))

    ;; row 1 — scan triggers
    (box :class "ws2-act-row" :orientation "h" :spacing 4
      (button :class "ws2-act-btn" :hexpand true
              :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json & ~/.config/eww/scripts/rf_live.sh &"
        (label :text "[r all]"))
      (button :class "ws2-act-btn" :hexpand true
              :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json &"
        (label :text "[r wifi]"))
      (button :class "ws2-act-btn" :hexpand true
              :onclick "~/.config/eww/scripts/rf_live.sh &"
        (label :text "[r arp]")))

    ;; row 2 — tools
    (box :class "ws2-act-row" :orientation "h" :spacing 4
      (button :class "ws2-act-btn" :hexpand true
              :onclick "eww open --toggle device-labels"
        (label :text "[labels]"))
      (button :class "ws2-act-btn" :hexpand true
              :onclick "~/.config/eww/scripts/rf_clr_new.sh &"
        (label :text "[clr new]"))
      (button :class "ws2-act-btn" :hexpand true
              :onclick "~/.config/eww/scripts/ws2_export.sh &"
        (label :text "[export]")))

    ;; row 3 — wardrive map
    (box :class "ws2-act-row" :orientation "h" :spacing 4
      (button :class "ws2-act-btn ws2-act-wardrive" :hexpand true
              :onclick "eww open --toggle wardrive-map"
        (label :text "[wardrive map]"))
      (label :class "wardrive-stat-sm" :hexpand true
             :text wardrive_stats :halign "end"))

    ;; live status — rf device counts + gateway ping
    (box :class "ws2-act-status" :orientation "h" :spacing 6 :valign "center"
      (label :class "label-dim" :text "rf:")
      (label :class "stat-val"  :hexpand true :text {"w:" + wifi_count + "  " + rf_summary})
      (label :class "label-dim" :text "gw:")
      (label :class "stat-val ws2-ping-val" :text ping_ms))

    ;; bandwidth bars — DN/UP from real iface counters
    (label :class "ws2-bw-txt" :halign "start" :wrap true :text net_bw)

    ;; ── ENTROPY ──────────────────────────────────────────────────────────────
    (box :class "scan-section-hdr" :orientation "h" :spacing 3 :valign "center"
      (label :class "scan-col-title" :hexpand true :text "[ ENTROPY ]" :halign "start")
      (label :class "rf-spinner ws2-hdr-spinner" :text rf_pulse))
    (label :class "ws2-entropy-bar" :halign "start" :text entropy_bar)
    (label :class "ws2-entropy-wave" :halign "start" :text entropy_wave)))

(defwindow ws2-actions
  :monitor 0
  :geometry (geometry :x "190px" :y "568px" :width "360px" :height "295px"
                      :anchor "top left")
  :stacking "bottom"
  :focusable false
  (w-ws2-actions))

;; ---- DEVICE LABELS POPUP ----
;; toggled by [labels] button in ws2-actions
;; tabbed: wifi / arp / bt — inline nick editor for each detected device

(defwidget w-device-labels []
  (box :class "labels-root" :orientation "v" :spacing 0

    ;; title bar
    (box :class "scan-topbar" :orientation "h" :spacing 0 :valign "center"
      (label :class "scan-title" :hexpand true :text "[ DEVICE LABELS ]" :halign "start")
      (button :class "scan-rbtn" :onclick "eww close device-labels"
        (label :text "[x]")))

    ;; tab row
    (box :class "labels-tabs" :orientation "h" :spacing 0
      (button :class {labels_tab == "wifi" ? "labels-tab labels-tab-active" : "labels-tab"}
              :onclick "eww update labels_tab=wifi"
        (label :text "[ wifi ]"))
      (button :class {labels_tab == "arp" ? "labels-tab labels-tab-active" : "labels-tab"}
              :onclick "eww update labels_tab=arp"
        (label :text "[ arp ]"))
      (button :class {labels_tab == "bt" ? "labels-tab labels-tab-active" : "labels-tab"}
              :onclick "eww update labels_tab=bt"
        (label :text "[ bt ]")))

    ;; wifi tab — list all APs, nick input keyed on bssid
    (revealer :reveal {labels_tab == "wifi"} :transition "none"
      (scroll :vscroll true :height 336 :class "scan-scroll"
        (box :orientation "v" :spacing 0
          (for ap in wifi_devices
            (box :class "labels-row" :orientation "h" :spacing 4 :valign "center"
              (label :class {"scan-wsig scan-wsig-" + ap.level}
                     :text {ap.bars} :width 26)
              (label :class "scan-dist" :text {ap.dist_s} :width 38)
              (label :class "labels-name" :hexpand true
                     :text {ap.ssid} :limit-width 18 :truncate true)
              (input :class "labels-input" :value ""
                     :onaccept {"~/.config/eww/scripts/rf_nick.sh '" + ap.bssid + "' '{}'"})
              (button :class "scan-cpbtn"
                      :onclick {"~/.config/eww/scripts/rf_nick.sh '" + ap.bssid + "' '-'"}
                (label :text "[-]")))))))

    ;; arp tab — list all ARP nodes, nick input keyed on IP
    (revealer :reveal {labels_tab == "arp"} :transition "none"
      (scroll :vscroll true :height 336 :class "scan-scroll"
        (box :orientation "v" :spacing 0
          (for device in arp_devices
            (box :class "labels-row" :orientation "h" :spacing 4 :valign "center"
              (label :class {"rf-sig " + device.state}
                     :text {device.sig} :width 26)
              (label :class {"scan-dist scan-dist-" + device.dist_s}
                     :text {device.dist_s} :width 38)
              (label :class "labels-name" :hexpand true
                     :text {device.display} :limit-width 16 :truncate true)
              (input :class "labels-input" :value ""
                     :onaccept {"~/.config/eww/scripts/rf_nick.sh '" + device.key + "' '{}'"})
              (button :class "scan-cpbtn"
                      :onclick {"~/.config/eww/scripts/rf_nick.sh '" + device.key + "' '-'"}
                (label :text "[-]")))))))

    ;; bt tab — list all paired/connected BT devices
    (revealer :reveal {labels_tab == "bt"} :transition "none"
      (scroll :vscroll true :height 336 :class "scan-scroll"
        (box :orientation "v" :spacing 0
          (for device in bt_devices
            (box :class "labels-row" :orientation "h" :spacing 4 :valign "center"
              (label :class {"rf-sig " + device.state}
                     :text {device.sig} :width 26)
              (label :class {"scan-dist scan-dist-" + device.dist_s}
                     :text {device.dist_s} :width 38)
              (label :class "labels-name" :hexpand true
                     :text {device.display} :limit-width 16 :truncate true)
              (input :class "labels-input" :value ""
                     :onaccept {"~/.config/eww/scripts/rf_nick.sh '" + device.key + "' '{}'"})
              (button :class "scan-cpbtn"
                      :onclick {"~/.config/eww/scripts/rf_nick.sh '" + device.key + "' '-'"}
                (label :text "[-]")))))))))

(defwindow device-labels
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "480px" :height "420px"
                      :anchor "center")
  :stacking "overlay"
  :focusable true
  (w-device-labels))

;; ---- WARDRIVE MAP WINDOW ----
;; Full AP history database: scatter map, sortable list, channel stats.
;; Open via [wardrive map] in ws2-actions or mod+shift+w keybind.

(defwidget w-wardrive-map []
  (box :class "wd-root" :orientation "v" :spacing 0

    ;; ── TOP BAR ────────────────────────────────────────────────────────────
    (box :class "wd-topbar" :orientation "h" :spacing 0 :valign "center"
      (label :class "wd-title" :hexpand true
             :text "[ WARDRIVE MAP ]" :halign "start")
      (label :class "rf-spinner" :text rf_pulse)
      (label :class "agent-sep"  :text "  ")
      (label :class "wardrive-stat-sm" :text wardrive_stats)
      (label :class "agent-sep"  :text "  ")
      (button :class "scan-rbtn"
              :onclick "~/.config/eww/scripts/wifi_scan.sh > /tmp/eww_wifi_scan.json &"
        (label :text "[r]"))
      (label :class "agent-sep" :text " ")
      (button :class "wd-close"
              :onclick "eww close wardrive-map"
        (label :text "[x]")))

    ;; ── TAB ROW ────────────────────────────────────────────────────────────
    (box :class "wd-tabs" :orientation "h" :spacing 0
      (button :class {wardrive_tab == "map"   ? "wd-tab wd-tab-active" : "wd-tab"}
              :onclick "eww update wardrive_tab=map"
        (label :text "[ map ]"))
      (button :class {wardrive_tab == "list"  ? "wd-tab wd-tab-active" : "wd-tab"}
              :onclick "eww update wardrive_tab=list"
        (label :text "[ list ]"))
      (button :class {wardrive_tab == "stats" ? "wd-tab wd-tab-active" : "wd-tab"}
              :onclick "eww update wardrive_tab=stats"
        (label :text "[ stats ]")))

    ;; ── MAP TAB ────────────────────────────────────────────────────────────
    (revealer :reveal {wardrive_tab == "map"} :transition "none"
      (scroll :class "wd-scroll" :vscroll true :hscroll false :height 340
        (label :class "wd-map-txt" :halign "start" :valign "start"
               :wrap false :text wardrive_map_frame)))

    ;; ── LIST TAB ───────────────────────────────────────────────────────────
    (revealer :reveal {wardrive_tab == "list"} :transition "none"
      (scroll :class "wd-scroll" :vscroll true :hscroll true :height 340
        (label :class "wd-list-txt" :halign "start" :valign "start"
               :wrap false :text wardrive_list_txt)))

    ;; ── STATS TAB ──────────────────────────────────────────────────────────
    (revealer :reveal {wardrive_tab == "stats"} :transition "none"
      (scroll :class "wd-scroll" :vscroll true :hscroll false :height 340
        (label :class "wd-stats-txt" :halign "start" :valign "start"
               :wrap false :text wardrive_stats_txt)))

    ;; ── FOCUS PANEL ────────────────────────────────────────────────────────
    ;; shows DB record for the AP currently focused in the scan panel
    (box :class "wd-focus-wrap" :orientation "v" :spacing 0
      (box :class "wd-focus-hdr" :orientation "h" :spacing 3 :valign "center"
        (label :class "wd-section" :hexpand true
               :text "[ FOCUSED ]" :halign "start")
        (label :class "wd-focused-key" :text scan_focused_key :limit-width 18))

      (scroll :class "wd-scroll" :vscroll true :height 88
        (label :class "wd-focus-txt" :halign "start" :valign "start"
               :wrap false :text wardrive_focus))

      ;; status action row
      (box :class "wd-actions" :orientation "h" :spacing 3 :valign "center"
        (label :class "wd-act-label" :text "mark:")
        (button :class "wd-act-btn wd-known"
                :onclick {"~/.config/eww/scripts/wardrive_status.sh '"
                          + scan_focused_key + "' known"}
          (label :text "[known]"))
        (button :class "wd-act-btn wd-watched"
                :onclick {"~/.config/eww/scripts/wardrive_status.sh '"
                          + scan_focused_key + "' watched"}
          (label :text "[watch]"))
        (button :class "wd-act-btn wd-flagged"
                :onclick {"~/.config/eww/scripts/wardrive_status.sh '"
                          + scan_focused_key + "' flagged"}
          (label :text "[flag]"))
        (button :class "wd-act-btn"
                :onclick {"~/.config/eww/scripts/wardrive_status.sh '"
                          + scan_focused_key + "' unknown"}
          (label :text "[unk]"))))))

(defwindow wardrive-map
  :monitor 0
  :geometry (geometry :x "50%" :y "50%" :width "560px" :height "540px"
                      :anchor "center")
  :stacking "overlay"
  :focusable true
  :namespace "eww-wardrive"
  (w-wardrive-map))
