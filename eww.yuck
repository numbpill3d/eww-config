;;;; ============================================================
;;;; EWW CONFIG // XENOTREK DASHBOARD // BLACK + RED
;;;; ============================================================

;; ---- VARIABLES ----
(defvar moodface "(^_^)")
(defvar agent_input "")
(defvar agent_mode "home")
(defvar scan_focused_key "")
(defvar labels_tab "arp")
(defvar scan_tab "wifi")
;; left sidebar slot 2: "sys" | "net"
(defvar lslot "sys")
;; rf panel mode: false=compact (more rows), true=detail (2-row)
(defvar rf_detail false)
;; wardrive-map window tab: "map" | "list" | "stats"
(defvar wardrive_tab "map")

;; ---- POLLS ----
(defpoll time_val    :interval "1s"   `date '+%H:%M:%S'`)
(defpoll date_val    :interval "60s"  `date '+%Y-%m-%d'`)
(defpoll cpu_val     :interval "3s"   `~/.config/eww/scripts/cpu.sh`)
(defpoll mem_val     :interval "5s"   `~/.config/eww/scripts/mem.sh`)
(defpoll disk_val    :interval "30s"  `~/.config/eww/scripts/disk.sh`)
(defpoll net_up      :interval "3s"   `~/.config/eww/scripts/net.sh up`)
(defpoll net_down    :interval "3s"   `~/.config/eww/scripts/net.sh down`)
(defpoll bat_val     :interval "30s"  `~/.config/eww/scripts/bat.sh pct`)
(defpoll bat_status  :interval "30s"  `~/.config/eww/scripts/bat.sh status`)
(defpoll cpu_bar     :interval "2s"   `~/.config/eww/scripts/vitals_bar.sh cpu`)
(defpoll mem_bar     :interval "3s"   `~/.config/eww/scripts/vitals_bar.sh mem`)
(defpoll wifi_ssid   :interval "10s"  `iwgetid -r 2>/dev/null || echo "none"`)

;; External daemon polls (written by background Python daemons)
(defpoll gh_commits    :interval "300s" `cat /tmp/eww_gh_commits   2>/dev/null || echo "?"`)
(defpoll gh_streak     :interval "300s" `cat /tmp/eww_gh_streak    2>/dev/null || echo "?"`)
(defpoll gh_repos      :interval "300s" `cat /tmp/eww_gh_repos     2>/dev/null || echo "?"`)
(defpoll yt_subs       :interval "300s" `cat /tmp/eww_yt_subs      2>/dev/null || echo "?"`)
(defpoll yt_views      :interval "300s" `cat /tmp/eww_yt_views     2>/dev/null || echo "?"`)
(defpoll yt_videos     :interval "300s" `cat /tmp/eww_yt_videos    2>/dev/null || echo "?"`)
(defpoll cc_tokens_day  :interval "60s" `cat /tmp/eww_cc_tokens_day  2>/dev/null || echo "0"`)
(defpoll cc_tokens_week :interval "60s" `cat /tmp/eww_cc_tokens_week 2>/dev/null || echo "0"`)
(defpoll cc_cost_day    :interval "60s" `cat /tmp/eww_cc_cost_day    2>/dev/null || echo "$0.00"`)
(defpoll cc_session     :interval "5s"  `cat /tmp/eww_cc_session 2>/dev/null || echo "idle"`)

;; RF scan — live ARP + bluetooth, returns JSON array of device objects
(defpoll rf_devices :interval "10s" :initial "[]"
  `~/.config/eww/scripts/rf_live.sh 2>/dev/null || echo '[]'`)
;; RF summary line written as side-effect by rf_live.sh (e.g. "a:3  b:1  !2")
(defpoll rf_summary :interval "10s"
  `cat /tmp/eww_rf_summary 2>/dev/null || echo "·"`)
;; spinning scan indicator — cycles |/-\ every 500ms for "live" feel
(defpoll rf_pulse :interval "500ms"
  `~/.config/eww/scripts/rf_pulse.sh`)


;; Hardware sensors — ThinkPad CPU temp, fan, load avg
(defpoll sensors_val :interval "10s"
  `~/.config/eww/scripts/sensors.sh 2>/dev/null || echo "tmp:?"`)

;; Current wifi link — signal dBm + tx rate
(defpoll wifi_rssi :interval "10s"
  `~/.config/eww/scripts/wifi_info.sh 2>/dev/null || echo "?"`)

;; Wardrive DB stats (written as side-effect of wifi_scan logging)
(defpoll wardrive_stats :interval "30s"
  `cat /tmp/eww_wardrive_stats 2>/dev/null || echo "db:0"`)

;; Wardrive map/list/stats frames — generated from DB
(defpoll wardrive_map_frame :interval "5s" :initial "scanning..."
  `python3 ~/.config/eww/scripts/wardrive_map.py map 2>/dev/null || echo "db empty"`)
(defpoll wardrive_list_txt  :interval "30s" :initial "loading..."
  `python3 ~/.config/eww/scripts/wardrive_map.py list 2>/dev/null || echo "db empty"`)
(defpoll wardrive_stats_txt :interval "60s" :initial "loading..."
  `python3 ~/.config/eww/scripts/wardrive_map.py stats 2>/dev/null || echo "db empty"`)

;; Wardrive focus — written by wardrive_db.py focus <bssid>
(defpoll wardrive_focus :interval "2s" :initial "[ select a wifi network to inspect ]"
  `cat /tmp/eww_wardrive_focus 2>/dev/null || echo "[ select a wifi network to inspect ]"`)

;; Agent polls
(defpoll agent_display :interval "500ms" `~/.config/eww/scripts/agent_display.sh`)
(defpoll agent_status  :interval "1s"    `cat /tmp/eww_agent_status 2>/dev/null || echo "idle"`)
(defpoll agent_model   :interval "5s"    `cat /tmp/eww_agent_model  2>/dev/null || echo "qwen2.5:3b"`)
(defpoll agent_matrix  :interval "500ms" `~/.config/eww/scripts/agent_matrix.sh`)

;; Second YT channel polls
(defpoll yt2_subs   :interval "300s" `cat /tmp/eww_yt2_subs   2>/dev/null || echo "?"`)
(defpoll yt2_views  :interval "300s" `cat /tmp/eww_yt2_views  2>/dev/null || echo "?"`)
(defpoll yt2_videos :interval "300s" `cat /tmp/eww_yt2_videos 2>/dev/null || echo "?"`)
(defpoll yt_title1  :interval "300s" `cat /tmp/eww_yt_title1  2>/dev/null || echo "CH1"`)
(defpoll yt_title2  :interval "300s" `cat /tmp/eww_yt_title2  2>/dev/null || echo "CH2"`)

;; Workspace 2 — wifi scan (reads /tmp/eww_wifi_scan.json, written by scan on demand)
;; [r] buttons write directly to this file; poll reads it at 5s for low latency
(defpoll wifi_devices :interval "5s" :initial "[]"
  `cat /tmp/eww_wifi_scan.json 2>/dev/null || echo '[]'`)

;; Workspace 2 — device focus detail (written by scan_focus.sh on row click)
(defpoll scan_focus_data :interval "1s" :initial "[ click any row to inspect ]"
  `cat /tmp/eww_scan_focus 2>/dev/null || echo "[ click any row to inspect ]"`)

;; Workspace 2 — ping sparkline (written by ping_daemon.sh every 3s)
(defpoll ping_ms    :interval "4s" `cat /tmp/eww_ping_ms    2>/dev/null || echo "·"`)
(defpoll ping_spark :interval "4s" `cat /tmp/eww_ping_spark 2>/dev/null || echo "········"`)

;; Workspace 2 — channel congestion (written by chan_daemon.py every 15s)
(defpoll chan_bars :interval "20s" `cat /tmp/eww_chan_bars 2>/dev/null || echo "awaiting scan"`)

;; Workspace 2 — live bandwidth bars from /sys/class/net (real iface counters)
(defpoll net_bw :interval "3s" :initial "DN[..........] --\nUP[..........] --"
  `~/.config/eww/scripts/net_bandwidth.sh 2>/dev/null || echo "no data"`)

;; Workspace 2 — DNS resolver + public IP (written by dns_probe.sh every 60s)
(defpoll dns_server :interval "30s" `cat /tmp/eww_dns_server 2>/dev/null || echo "?"`)
(defpoll pub_ip     :interval "60s" `cat /tmp/eww_pubip      2>/dev/null || echo "?"`)

;; Workspace 2 — ARP-only and BT-only filtered views, with colorclass merged from device_colors
(defpoll arp_devices :interval "11s" :initial "[]"
  `python3 ~/.config/eww/scripts/rf_filter.py arp 2>/dev/null || echo '[]'`)
(defpoll bt_devices :interval "12s" :initial "[]"
  `python3 ~/.config/eww/scripts/rf_filter.py bt 2>/dev/null || echo '[]'`)

;; Workspace 2 — Halo-3 radar frame (500ms poll for smooth sweep)
(defpoll radar_frame :interval "500ms" :initial "RADAR  0 contacts\n"
  `python3 ~/.config/eww/scripts/radar_ws2.py 2>/dev/null || echo "RADAR  error"`)

;; Workspace 2 — wifi network count for scan panel header
(defpoll wifi_count :interval "10s" :initial "0"
  `cat /tmp/eww_wifi_scan.json 2>/dev/null | python3 -c "import sys,json; d=json.load(sys.stdin); print(len(d))" 2>/dev/null || echo "0"`)

;; Workspace 2 — kernel entropy pool
(defpoll entropy_bar  :interval "2s"    :initial "[....................] 0"
  `~/.config/eww/scripts/entropy.sh 2>/dev/null || echo "[....................] ?"`)
(defpoll entropy_wave :interval "300ms" :initial "· · · · · · · · · · · · · ·  "
  `~/.config/eww/scripts/entropy_wave.sh 2>/dev/null || echo "· · · · · · · · · · · · · ·  "`)

;; ---- WIDGETS ----

;; Clock block
(defwidget w-clock []
  (box :class "panel clock-panel" :orientation "v" :spacing 0
    (box :orientation "h" :spacing 6
      (label :class "clock-time" :text time_val)
      (label :class "clock-date" :text date_val :valign "end"))
    (label :class "label-dim" :text wifi_ssid)))

;; Merged slot widget — sys/net share identical structure, only text swaps
;; No height change between modes, so the exclusive sidebar window never repositions
(defwidget w-vitals []
  (box :class "panel" :orientation "v" :spacing 2
    (box :orientation "h" :spacing 3 :valign "center"
      (label :class "section-label"
             :text {lslot == "sys" ? "[ SYS ]" : "[ NET ]"}
             :hexpand true :halign "start")
      (button :class "slot-cycle-btn"
              :onclick {lslot == "sys" ? "eww update lslot=\"net\"" : "eww update lslot=\"sys\""}
        (label :text {lslot == "sys" ? "[>]" : "[x]"})))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "CPU" : "DN"})
      (label :class "stat-val"  :text {lslot == "sys" ? cpu_val : net_down}))
    (label :class "stat-bar" :text {lslot == "sys" ? cpu_bar : ""} :halign "start")
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "MEM" : "UP"})
      (label :class "stat-val"  :text {lslot == "sys" ? mem_val : net_up}))
    (label :class "stat-bar" :text {lslot == "sys" ? mem_bar : ping_spark} :halign "start")
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "DSK" : "ping"})
      (label :class "stat-val"  :text {lslot == "sys" ? disk_val : ping_ms + "ms"}))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "NET" : "dns"})
      (label :class "stat-val"  :text {lslot == "sys" ? net_up + " / " + net_down : dns_server}))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "BAT" : "pub"})
      (label :class "stat-val"  :text {lslot == "sys" ? bat_val + "% " + bat_status : pub_ip}))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text {lslot == "sys" ? "HW" : "rf"})
      (label :class "stat-val"  :text {lslot == "sys" ? sensors_val : wifi_rssi}))))

;; RF scan — compact (default) or detail view, toggled with [+]/[-]
(defwidget w-rf-radar []
  (box :class "panel rf-panel" :orientation "v" :spacing 2
    ;; header: label + spinner + summary + detail-toggle + reload
    (box :orientation "h" :spacing 3 :valign "center"
      (label :class "section-label" :text "[ RF ]" :halign "start")
      (label :class "rf-spinner" :text rf_pulse)
      (label :class "rf-summary" :hexpand true :halign "start" :text rf_summary)
      (button :class "rf-detail-toggle"
              :onclick {rf_detail ? "eww update rf_detail=false" : "eww update rf_detail=true"}
        (label :text {rf_detail ? "[-]" : "[+]"}))
      (button :class "rf-scan-micro" :onclick "eww poll rf_devices"
        (label :text "[r]")))
    ;; compact: 1-row always visible, detail row revealed on toggle
    ;; compact scroll taller so more devices fit; shrinks when detail opens
    (scroll :vscroll true :height {rf_detail ? 130 : 210}
      (box :orientation "v" :spacing 1
        (for device in rf_devices
          (box :class {"rf-device rf-" + device.new} :orientation "v" :spacing 0
            ;; primary row — always visible
            (button :class "rf-row-btn"
                    :onclick {"wl-copy '" + device.key + "'"}
              (box :orientation "h" :spacing 2
                (label :class {"rf-sig " + device.state}
                       :text {device.sig} :width {rf_detail ? 26 : 22})
                (label :class {"rf-badge " + device.proto}
                       :text {device.proto} :width {rf_detail ? 22 : 18})
                (label :class {"rf-name " + device.new} :hexpand true
                       :text {device.display} :truncate true
                       :limit-width {rf_detail ? 14 : 10})
                (label :class {"rf-state " + device.state}
                       :text {rf_detail ? device.state_s : device.addr}
                       :limit-width {rf_detail ? 5 : 11})))
            ;; detail-only second row: addr + oui + mark
            (revealer :reveal rf_detail :duration "80ms"
              (box :orientation "h" :spacing 3
                (label :class "rf-addr-sm" :text {device.addr}
                       :width 70 :truncate true :limit-width 15)
                (label :class "rf-oui" :hexpand true :text {device.oui})
                (button :class "rf-mark-btn"
                        :onclick {"~/.config/eww/scripts/rf_mark.sh '" + device.key + "'"}
                  (label :text "+kn"))))))))))

;; GitHub stats
(defwidget w-github []
  (box :class "panel" :orientation "v" :spacing 3
    (label :class "section-label" :text "[ GH: numbpill3d ]" :halign "start")
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "commits")
      (label :class "stat-val accent" :text gh_commits))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "streak")
      (label :class "stat-val" :text {gh_streak + "d"}))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "repos")
      (label :class "stat-val" :text gh_repos))))

;; YouTube stats
(defwidget w-youtube []
  (box :class "panel" :orientation "v" :spacing 3
    (label :class "section-label" :text "[ YT: AI Explains AI ]" :halign "start")
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "subs")
      (label :class "stat-val accent" :text yt_subs))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "views")
      (label :class "stat-val" :text yt_views))))

;; Claude Code token tracker
(defwidget w-claudecode []
  (box :class "panel" :orientation "v" :spacing 3
    (box :orientation "h" :spacing 3 :valign "center"
      (label :class "section-label" :text "[ CC TOKENS ]" :hexpand true :halign "start")
      (label :class {"agent-status-dot " + cc_session}
             :text {cc_session == "active" ? "●" : "·"}))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "today")
      (label :class "stat-val accent" :text cc_tokens_day))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "week")
      (label :class "stat-val" :text cc_tokens_week))
    (box :class "stat-row" :orientation "h" :spacing 6
      (label :class "label-dim" :text "cost")
      (label :class "stat-val" :text cc_cost_day))))

;; Net slot — replaces sys vitals when lslot="net"
(defwidget w-net-bw []
  (box :class "panel" :orientation "v" :spacing 2
    (box :orientation "h" :spacing 3 :valign "center"
      (label :class "section-label" :text "[ NET ]" :hexpand true :halign "start")
      (button :class "slot-cycle-btn" :onclick "eww update lslot=\"sys\""
        (label :text "[x]")))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text "DN")
      (label :class "stat-val accent" :text net_down))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text "UP")
      (label :class "stat-val" :text net_up))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text "ping")
      (label :class "stat-val" :text {ping_ms + "ms"}))
    (label :class "stat-bar" :text ping_spark :halign "start")
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text "dns")
      (label :class "stat-val" :text dns_server))
    (box :class "stat-row" :orientation "h" :spacing 4
      (label :class "label-dim" :text "pub")
      (label :class "stat-val" :text pub_ip))))

;; Sway keybindings reference — toggle with mod+/
(defwidget w-keybindings []
  (box :class "kb-root" :orientation "v" :spacing 1
    (label :class "kb-title" :text "[ SWAY KEYS ]   mod = super" :halign "center")

    (label :class "kb-group" :text "FOCUS / MOVE" :halign "start")
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+h/j/k/l")
      (label :class "kb-desc" :text "focus left/down/up/right"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+sft+h/j/k/;")
      (label :class "kb-desc" :text "move window left/down/up/right"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+a")
      (label :class "kb-desc" :text "focus parent"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+space")
      (label :class "kb-desc" :text "toggle focus float/tile"))

    (label :class "kb-group" :text "WINDOW" :halign "start")
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+q")
      (label :class "kb-desc" :text "kill window"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+f")
      (label :class "kb-desc" :text "fullscreen toggle"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+shift+space")
      (label :class "kb-desc" :text "float toggle"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+r")
      (label :class "kb-desc" :text "resize mode (hjkl/esc)"))

    (label :class "kb-group" :text "LAYOUT" :halign "start")
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+b / mod+v")
      (label :class "kb-desc" :text "split horiz / vert"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+s")
      (label :class "kb-desc" :text "stacking layout"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+w")
      (label :class "kb-desc" :text "tabbed layout"))
    (box :class "kb-row" :orientation "h" :spacing 4
      (label :class "kb-key"  :text "mod+e")
